# Copy to .env.local and fill in real values. .env.local is gitignored.

# Signs the proposal session JWT set by /api/proposals/verify and read by
# /api/proposals/download. Must be at least 32 characters. Generate with:
#
#   openssl rand -base64 32
#
# Rotate by changing this value — all existing sessions invalidate on
# restart, users just re-enter their code.
PROPOSAL_SESSION_SECRET=change-me-at-least-32-characters-long

# --- Rate limiting (optional but strongly recommended for production) ---
#
# If both values below are set, proposal rate limits are stored in Upstash
# Redis — state is shared across replicas and survives restarts. If left
# unset the rate limiter falls back to an in-memory Map, which is fine for
# `next dev` or a single-container deployment but MUST NOT be relied on
# behind a load balancer: attackers get N× the attempts with N replicas.
#
# Provision a free-tier DB at https://console.upstash.com/redis, then copy
# the REST URL + REST TOKEN here (Upstash provides both on the DB page).
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
