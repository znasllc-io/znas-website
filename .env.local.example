# Copy to .env.local and fill in real values. .env.local is gitignored.

# Signs the proposal session JWT set by /api/proposals/verify and read by
# /api/proposals/download. Must be at least 32 characters. Generate with:
#
#   openssl rand -base64 32
#
# Rotate by changing this value — all existing sessions invalidate on
# restart, users just re-enter their code.
PROPOSAL_SESSION_SECRET=change-me-at-least-32-characters-long
