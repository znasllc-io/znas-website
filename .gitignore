# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# Proposal data — contains client content + argon2id password hashes.
# See data/proposals/README.md. Only the *.example.json template is tracked.
/data/proposals/*.json
!/data/proposals/*.example.json

# Local working PDFs and drafts. NEVER commit these — they hold draft
# proposals, source documents, and exports that should not leave this
# machine. Production PDFs live in data/proposals/pdfs/ (force-added)
# and are served only through the auth-gated /api/proposals/download
# endpoint, never via the static /public folder.
/pdf files/
/*.pdf
/*.zip
/Untitled*.png
/agent-output/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
